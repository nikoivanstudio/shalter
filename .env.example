NODE_ENV=development
AUTH_SECRET=change-me

# Public app URL used for billing return links and webhooks.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# YooKassa hosted checkout.
# Card details are entered only on the YooKassa side.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Optional aliases supported by the codebase.
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# Optional WebRTC relay config for calls in production.
STUN_SERVER_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVER_URLS=
TURN_USERNAME=
TURN_PASSWORD=
