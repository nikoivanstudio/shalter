{
  "name": "shalter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "db:ensure-dialog-title": "prisma db execute --file prisma/migrations/20260408013000_add_dialog_title/migration.sql",
    "db:prepare": "node scripts/db-prepare.mjs",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:resolve:fix-contact-model": "prisma migrate resolve --applied 20260402192247_fix_contact_model",
    "start": "next start",
    "start:prod": "npm run db:prepare && next start",
    "lint": "eslint",
    "test:unit": "jest --config jest.config.js",
    "test:components": "vitest run --config vitest.config.ts",
    "test:coverage": "npm run test:unit -- --coverage && npm run test:components -- --coverage.enabled true && node scripts/merge-coverage.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-istanbul": "^4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest": "^30.3.0",
    "jsdom": "^29.0.2",
    "nyc": "^18.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
