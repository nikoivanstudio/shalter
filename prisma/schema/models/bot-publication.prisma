model BotPublication {
  id          Int      @id @default(autoincrement())
  ownerId     Int      @map("owner_id")
  owner       User     @relation("OwnedBotPublications", fields: [ownerId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(120)
  username    String   @unique @db.VarChar(32)
  niche       String?  @db.VarChar(120)
  audience    String   @db.VarChar(20)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(512)
  isBlocked   Boolean  @default(false) @map("is_blocked")
  config      Json
  publishedAt DateTime @default(now()) @map("published_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([ownerId, publishedAt])
  @@index([isBlocked, publishedAt])
  @@map("bot_publications")
}
