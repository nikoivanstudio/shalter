model ChannelMessage {
  id        Int      @id @default(autoincrement())
  channelId Int      @map("channel_id")
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  Int      @map("author_id")
  author    User     @relation("ChannelMessages", fields: [authorId], references: [id], onDelete: Cascade)
  content   String   @db.VarChar(1000)
  mediaKind String?  @map("media_kind") @db.VarChar(20)
  mediaUrl  String?  @map("media_url") @db.VarChar(512)
  mediaName String?  @map("media_name") @db.VarChar(255)
  mediaMime String?  @map("media_mime") @db.VarChar(100)
  mediaSize Int?     @map("media_size")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([channelId, id])
  @@index([authorId])
  @@map("channel_messages")
}
