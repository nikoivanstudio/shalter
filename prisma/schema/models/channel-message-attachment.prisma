model ChannelMessageAttachment {
  id               Int            @id @default(autoincrement())
  channelMessageId Int            @map("channel_message_id")
  channelMessage   ChannelMessage @relation(fields: [channelMessageId], references: [id], onDelete: Cascade)
  kind             String         @db.VarChar(20)
  url              String         @db.VarChar(512)
  name             String         @db.VarChar(255)
  mime             String         @db.VarChar(100)
  size             Int
  position         Int            @default(0)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([channelMessageId, position])
  @@map("channel_message_attachments")
}
