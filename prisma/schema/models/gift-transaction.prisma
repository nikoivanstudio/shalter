model GiftTransaction {
  id          Int      @id @default(autoincrement())
  senderId    Int?     @map("sender_id")
  recipientId Int      @map("recipient_id")
  giftKey     String   @map("gift_key") @db.VarChar(60)
  giftName    String   @map("gift_name") @db.VarChar(120)
  starsSpent  Int      @map("stars_spent")
  note        String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  sender      User?    @relation("SentGiftTransactions", fields: [senderId], references: [id], onDelete: SetNull)
  recipient   User     @relation("ReceivedGiftTransactions", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("gift_transactions")
}
