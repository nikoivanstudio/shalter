model PurchaseRequest {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  reviewedByUserId Int?      @map("reviewed_by_user_id")
  productKey       String    @map("product_key") @db.VarChar(40)
  amountRub        Int       @map("amount_rub")
  premiumMonths    Int       @default(0) @map("premium_months")
  starsAmount      Int       @default(0) @map("stars_amount")
  status           String    @db.VarChar(20)
  note             String?   @db.VarChar(255)
  paymentProvider  String?   @map("payment_provider") @db.VarChar(40)
  providerPaymentId String?  @map("provider_payment_id") @db.VarChar(128)
  providerStatus   String?   @map("provider_status") @db.VarChar(40)
  checkoutUrl      String?   @map("checkout_url") @db.VarChar(1024)
  createdAt        DateTime  @default(now()) @map("created_at")
  paidAt           DateTime? @map("paid_at")
  reviewedAt       DateTime? @map("reviewed_at")
  user             User      @relation("UserPurchaseRequests", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy       User?     @relation("ReviewedPurchaseRequests", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([providerPaymentId])
  @@map("purchase_requests")
}
