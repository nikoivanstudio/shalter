model Contact {
  id            Int  @id @default(autoincrement())
  ownerId       Int  @map("owner_id")
  owner         User @relation("OwnedContacts", fields: [ownerId], references: [id], onDelete: Cascade)
  contactUserId Int  @map("contact_user_id")
  contactUser   User @relation("UserInContacts", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactUserId])
  @@index([contactUserId])

  @@map("contacts")
}
