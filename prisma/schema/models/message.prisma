model Message {
  id        Int       @id @default(autoincrement())
  content   String    @db.VarChar(1000)
  status    String    @default("SENT") @db.VarChar(20)
  mediaKind String?   @map("media_kind") @db.VarChar(20)
  mediaUrl  String?   @map("media_url") @db.VarChar(512)
  mediaName String?   @map("media_name") @db.VarChar(255)
  mediaMime String?   @map("media_mime") @db.VarChar(100)
  mediaSize Int?      @map("media_size")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")
  dialogId  Int       @map("dialog_id")
  dialog    Dialog    @relation(fields: [dialogId], references: [id])
  authorId  Int
  author    User      @relation(fields: [authorId], references: [id])

  @@map("messages")
}
