model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(128)
  passwordHash String    @map("password_hash")
  phone        String    @unique @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  firstName    String    @map("first_name") @db.VarChar(40)
  role         String    @db.VarChar(20)
  lastName     String?   @map("last_name") @db.VarChar(40)
  avatarId     Int?      @map("avatar_id")
  avatarTone   String?   @map("avatar_tone") @db.VarChar(20)
  isBlocked    Boolean   @default(false) @map("is_blocked")
  lastSeenAt   DateTime? @map("last_seen_at")
  updatedAt    DateTime  @map("updated_at")
  ownedContacts Contact[] @relation("OwnedContacts")
  inContacts    Contact[] @relation("UserInContacts")
  ownedBlacklistEntries UserBlacklist[] @relation("OwnedBlacklistEntries")
  blockedByUsers        UserBlacklist[] @relation("BlockedByUsers")
  pushSubscriptions PushSubscription[]
  dialogs      Dialog[]
  messages     Message[]
  blockedInDialogs DialogBlockedUser[] @relation("BlockedDialogUser")
  blockedDialogActions DialogBlockedUser[] @relation("DialogBlockedByUser")
  ownedChannels        Channel[]            @relation("OwnedChannels")
  channelMemberships   ChannelParticipant[] @relation("ChannelMemberships")
  channelMessages      ChannelMessage[]     @relation("ChannelMessages")
  newsPosts            NewsPost[]           @relation("NewsPosts")
  newsPostLikes        NewsPostLike[]       @relation("NewsPostLikes")
  newsPostComments     NewsPostComment[]    @relation("NewsPostComments")

  @@map("users")
}
