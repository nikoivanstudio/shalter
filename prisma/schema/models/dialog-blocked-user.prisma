model DialogBlockedUser {
  id          Int      @id @default(autoincrement())
  dialogId    Int      @map("dialog_id")
  dialog      Dialog   @relation(fields: [dialogId], references: [id], onDelete: Cascade)
  userId      Int      @map("user_id")
  user        User     @relation("BlockedDialogUser", fields: [userId], references: [id], onDelete: Cascade)
  blockedById Int      @map("blocked_by_id")
  blockedBy   User     @relation("DialogBlockedByUser", fields: [blockedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([dialogId, userId])
  @@map("dialog_blocked_users")
}
