model UserBlacklist {
  id            Int      @id @default(autoincrement())
  ownerId       Int      @map("owner_id")
  owner         User     @relation("OwnedBlacklistEntries", fields: [ownerId], references: [id], onDelete: Cascade)
  blockedUserId Int      @map("blocked_user_id")
  blockedUser   User     @relation("BlockedByUsers", fields: [blockedUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([ownerId, blockedUserId])
  @@index([blockedUserId])
  @@map("user_blacklist")
}
